{{ if and (eq .osid "linux-debian") .personal -}}
#!/bin/sh

echo "Installing pass-cli..."
curl -fsSL https://proton.me/download/pass-cli/install.sh | bash

result="$(pass-cli info 2>/dev/null)"
ret=$?

echo "$result" | grep -q "garnier.hugo"
if [ $? -eq 0 ]; then
    echo "OK"
else
    pass-cli logout --force
    export PROTON_PASS_KEY_PROVIDER=fs
    pass-cli login
fi

pass-cli ssh-agent load

{{ end -}}
